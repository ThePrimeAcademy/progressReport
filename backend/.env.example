PORT=5000

# Email (Brevo HTTP API) — required to send report cards.
# Uses HTTPS, so it works from any cloud host (Railway blocks SMTP). The API
# key doesn't expire; recipients see the report as from your verified sender.
#
# Setup:
#   1. Sign up free at https://www.brevo.com/
#   2. Add a verified sender at https://app.brevo.com/senders/list — Brevo
#      sends a click-to-confirm email to that address.
#   3. Generate an API key at https://app.brevo.com/settings/keys/api
#   4. Paste the key below (and on Railway).
BREVO_API_KEY=

# Sender shown in the From: header. Must match a verified sender in Brevo.
# Format: "Display Name <email@example.com>" or just "email@example.com".
EMAIL_FROM="Prime Academy <you@example.com>"
