PORT=5000

# Email (SMTP via nodemailer) — required to send report cards from /api/report/email.
# Works with any SMTP provider: Gmail, iCloud, Outlook, Resend, etc.
#
# Gmail (easiest, no domain needed):
#   1. Turn on 2-Step Verification on your Google account.
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Set SMTP_USER to your gmail address, SMTP_PASS to the 16-char app password.
SMTP_USER=
SMTP_PASS=
# Optional — defaults shown:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# EMAIL_FROM defaults to SMTP_USER if unset
# EMAIL_FROM="Prime Academy <you@gmail.com>"
