PORT=5000

# ── Email ──────────────────────────────────────────────────────────────────
# Railway Free/Hobby BLOCKS outbound SMTP (ports 465/587). That is why Zoho
# Mail SMTP times out from production. Use ZeptoMail HTTPS instead.
#
# 1) Create a free ZeptoMail account: https://www.zoho.com/zeptomail/
# 2) Verify your domain (SPF/DKIM) in a Mail Agent
# 3) Mail Agent → SMTP/API → Send Mail Token → copy token
# 4) Set on Railway:
ZEPTOMAIL_TOKEN=
EMAIL_FROM="Prime Academy <admin@primeacademynova.com>"

# Optional legacy SMTP — only works on Railway Pro+ (SMTP unblocked):
# ZOHO_USER=admin@primeacademynova.com
# ZOHO_APP_PASSWORD=
# SMTP_HOST=smtppro.zoho.com
# SMTP_PORT=465
