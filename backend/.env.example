PORT=5000

# Email (Gmail API over HTTPS) — required to send report cards.
# Sends FROM your Gmail account via Google's REST API. Used instead of SMTP
# because Railway (and most managed hosts) block outbound SMTP ports.
#
# Setup is documented at the top of src/scripts/get-gmail-refresh-token.js.
# TL;DR:
#   1. Google Cloud Console > new project > enable Gmail API.
#   2. Configure OAuth consent screen (External, add yourself as a test user).
#   3. Credentials > OAuth client ID > Desktop app. Copy the client ID + secret.
#   4. Run locally:
#        cd backend
#        GOOGLE_CLIENT_ID="..." GOOGLE_CLIENT_SECRET="..." \
#          node src/scripts/get-gmail-refresh-token.js
#      Paste the printed refresh token below (and into Railway).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional. If unset, Gmail uses the authenticated account's primary address.
# Must match the Gmail account or one of its Send-As aliases.
# EMAIL_FROM="Prime Academy <you@gmail.com>"
