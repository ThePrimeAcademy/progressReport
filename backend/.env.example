PORT=5000

# Email (Zoho Mail over SMTP) — required to send report cards.
# Sends via nodemailer using a Zoho app-specific password (Zoho > Settings >
# Security > App Passwords), so 2FA on the account doesn't block sending.
#   ZOHO_USER          — the full Zoho mailbox address
#   ZOHO_APP_PASSWORD  — the app password (spaces in the displayed value are ok)
ZOHO_USER=
ZOHO_APP_PASSWORD=

# SMTP host/port. Either ZOHO_* or SMTP_* names work (Railway often uses SMTP_*).
# Prefer 465 (SSL) on Railway — 587 often hits "Connection timeout" from cloud hosts.
# Org / domain mailboxes:
#   SMTP_HOST=smtppro.zoho.com
#   SMTP_PORT=465
# Personal Zoho mailboxes:
#   SMTP_HOST=smtp.zoho.com
#   SMTP_PORT=465
# The app also auto-tries common Zoho host/port combos if the primary times out.
# ZOHO_HOST=smtppro.zoho.com
# ZOHO_PORT=465
# SMTP_HOST=smtppro.zoho.com
# SMTP_PORT=465

# Optional. Defaults to ZOHO_USER. Must be the Zoho mailbox or a verified alias.
# EMAIL_FROM="Prime Academy <admin@primeacademynova.com>"
